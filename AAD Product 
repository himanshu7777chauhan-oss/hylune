app.post("/admin/product", auth, (req, res) => {
  const db = loadDB();

  const product = {
    id: Date.now(),
    ...req.body
  };

  if (!validateProduct(product)) {
    return res.status(400).json({ error: "Invalid product data" });
  }

  db.products.push(product);
  saveDB(db);

  res.json({ success: true });
});