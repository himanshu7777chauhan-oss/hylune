const express = require("express");
require("dotenv").config();

const app = express();

// basic route (so browser shows something)
app.get("/", (req, res) => {
  res.send("Hylune server is running");
});

const PORT = process.env.PORT || 3000;

app.listen(PORT, () => {
  console.log(`Hylune running on port ${PORT}`);
});